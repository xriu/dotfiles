{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/refs/heads/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "hashline_edit": true,
  "disabled_mcps": [],
  "agents": {
    "prometheus": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "metis": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "atlas": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "sisyphus": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "sisyphus-junior": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4"
    },
    "momus": {
      "model": "github-copilot/gpt-5.4"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4"
    },
    "librarian": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "explore": {
      "model": "bailian-coding-plan/MiniMax-M2.5"
    },
    "multimodal-looker": {
      "model": "google/gemini-3-flash-preview"
    },
    "build": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "plan": {
      "model": "bailian-coding-plan/kimi-k2.5"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "variant": "max"
    },
    "deep": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "variant": "max"
    },
    "unspecified-low": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview"
    },
    "quick": {
      "model": "bailian-coding-plan/MiniMax-M2.5"
    },
    "writing": {
      "model": "bailian-coding-plan/MiniMax-M2.5"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  }
}
