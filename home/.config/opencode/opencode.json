{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "permission": {
        "codesearch": "allow",
        "doom_loop": "allow",
        "list": "allow",
        "lsp": "allow",
        "skill": "allow",
        "task": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "websearch": "allow",
        "bash": {
            "git diff": "allow",
            "git status": "allow",
            "git log": "allow",
            "git show": "allow",
            "git branch": "allow"
        },
        "external_directory": {
            "*": "ask",
            "~/.aws/**": "deny"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.envrc": "deny",
            "secrets/*": "deny",
            ".dev.vars": "ask"
        }
    },
    "model": "synthetic/hf:moonshotai/Kimi-K2.6",
    "agent": {
        "plan": {
            "mode": "primary",
            "model": "synthetic/hf:moonshotai/Kimi-K2.6",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true,
                "skill": true,
                "webfetch": true
            }
        },
        "build": {
            "mode": "primary",
            "model": "synthetic/hf:moonshotai/Kimi-K2.6",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true,
                "skill": true,
                "webfetch": true
            }
        },
        "ask": {
            "model": "synthetic/hf:moonshotai/Kimi-K2.6",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true,
                "skill": true,
                "webfetch": true
            }
        }
    },
    "mcp": {
        "aws-knowledge-mcp": {
            "enabled": true,
            "type": "remote",
            "url": "https://knowledge-mcp.global.api.aws"
        },
        "codebase-memory-mcp": {
            "enabled": true,
            "type": "local",
            "command": ["/Users/xavier.riu/.local/bin/codebase-memory-mcp"]
        }
    },
    "provider": {
        "bailian-coding-plan": {
            "npm": "@ai-sdk/anthropic",
            "name": "Model Studio Coding Plan",
            "options": {
                "baseURL": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1",
                "apiKey": "{env:ALIBABA_API_KEY}"
            },
            "models": {
                "qwen3.5-plus": {
                    "name": "Qwen3.5 Plus",
                    "modalities": {
                        "input": ["text", "image"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 8192
                        }
                    },
                    "limit": {
                        "context": 1000000,
                        "output": 65536
                    }
                }
            }
        }
    }
}
