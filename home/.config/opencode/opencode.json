{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "codesearch": "allow",
    "doom_loop": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "bash": {
      "git diff": "allow",
      "git status": "allow",
      "git log": "allow",
      "git show": "allow",
      "git branch": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.aws/**": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny",
      ".dev.vars": "ask"
    }
  },
  "model": "synthetic/hf:moonshotai/Kimi-K2.5",
  "plugin": [],
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "synthetic/hf:moonshotai/Kimi-K2.5",
      "prompt": "{file:./prompts/persona.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "skill": true,
        "webfetch": true
      }
    },
    "build": {
      "mode": "primary",
      "model": "synthetic/hf:moonshotai/Kimi-K2.5",
      "prompt": "{file:./prompts/persona.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true,
        "webfetch": true
      }
    },
    "ask": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5",
      "prompt": "{file:./prompts/persona.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "skill": true,
        "webfetch": true
      }
    }
  },
  "mcp": {
    "solo": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:45678"
    },
    "aws-knowledge-mcp": {
      "enabled": true,
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "gh-grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"]
    },
    "vibe-kanban": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "vibe-kanban@latest", "--mcp"]
    }
  },
  "provider": {
    "bailian-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "Model Studio Coding Plan",
      "options": {
        "baseURL": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1",
        "apiKey": "{env:ALIBABA_API_KEY}"
      },
      "models": {
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "qwen3-max-2026-01-23": {
          "name": "Qwen3 Max 2026-01-23"
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next"
        },
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus"
        },
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        }
      }
    }
  }
}
