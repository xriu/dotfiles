  "languages": {
    "JSON": {
      "tab_size": 4,
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
  },
  "load_direnv": "direct",
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
    },
  },
  "minimap": {
    "current_line_highlight": "line",
    "show": "auto",
  },
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "button": true,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 15,
    "scrollbar": {
      "show": "never",
    },
    "starts_open": true,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "show_edit_predictions": true,
  "show_whitespaces": "none",
  "show_wrap_guides": false,
  "soft_wrap": "editor_width",
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "terminal_controlled",
    "button": true,
    "copy_on_select": true,
    "detect_venv": {
      "on": {
        "activate_script": "default",
        "directories": [".env", "env", ".venv", "venv"],
      },
    },
    "dock": "bottom",
    "env": {
      "SHELL": "\"/opt/homebrew/bin/fish\"",
    },
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 13,
    "option_as_meta": false,
    "shell": "system",
    "working_directory": "current_project_directory",
  },
  "theme": {
    "dark": "Ayu Dark",
    "light": "Gruvbox Light",
    "mode": "dark",
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
  },
  "ui_font_size": 15,
  "use_system_window_tabs": true,
  "wrap_guides": [80, 120],
}
