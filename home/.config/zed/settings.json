{
  "agent": {
    "button": true,
    "commit_message_instructions": "Use the Conventional Commits format: <type>(<scope>): <description>.",
    "commit_message_model": {
      "model": "gemma4:e2b",
      "provider": "ollama",
    },
    "default_model": {
      "effort": "xhigh",
      "enable_thinking": true,
      "model": "go/deepseek-v4-pro",
      "provider": "opencode",
    },
    "default_profile": "write",
    "dock": "left",
    "enable_feedback": false,
    "enabled": true,
    "favorite_models": [
      {
        "effort": "xhigh",
        "enable_thinking": true,
        "model": "go/deepseek-v4-pro",
        "provider": "opencode",
      },
      {
        "effort": "xhigh",
        "enable_thinking": true,
        "model": "go/deepseek-v4-flash",
        "provider": "opencode",
      },
      {
        "enable_thinking": false,
        "model": "go/qwen3.7-max",
        "provider": "opencode",
      },
      {
        "enable_thinking": false,
        "model": "go/kimi-k2.7",
        "provider": "opencode",
      },
      {
        "enable_thinking": false,
        "model": "go/kimi-k2.6",
        "provider": "opencode",
      },
      {
        "enable_thinking": false,
        "model": "hf:MiniMaxAI/MiniMax-M3",
        "provider": "Synthetic",
      },
    ],
    "play_sound_when_agent_done": "never",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://github\\.com",
            },
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com",
            },
          ],
        },
      },
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "pi-acp": {
      "type": "registry",
    },
  },
  "auto_indent_on_paste": false,
  "auto_update": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 13,
  "buffer_line_height": {
    "custom": 1.5,
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "right",
  },
  "colorize_brackets": true,
  "confirm_quit": true,
  "context_servers": {},
  "cursor_blink": true,
  "diff_view_style": "split",
  "disable_ai": false,
  "edit_predictions": {
    "open_ai_compatible_api": {
      "api_url": "https://opencode.ai/zen/go/v1/chat/completions",
      "model": "deepseek-v4-flash",
    },
    "provider": "open_ai_compatible_api",
  },
  "enable_language_server": true,
  "ensure_final_newline_on_save": true,
  "feature_flags": {
    "edit_prediction_provider": "zed",
  },
  "file_types": {
    "hcl": ["*.hcl"],
    "tailwindcss": ["*.css"],
    "Terraform": ["*.tf", "*.tftpl"],
    "terraform": ["*.tf", "*.tftpl"],
    "Terraform-vars": ["*.tfvars"],
    "terraform-vars": ["*.tfvars"],
  },
  "format_on_save": "on",
  "formatter": "auto",
  "git": {
    "inline_blame": {
      "delay_ms": 500,
      "enabled": true,
    },
  },
  "git_panel": {
    "dock": "right",
  },
  "hard_tabs": false,
  "icon_theme": {
    "dark": "Material Icon Theme",
    "light": "Material Icon Theme",
    "mode": "dark",
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
    "enabled": true,
  },
  "language_models": {
    "anthropic": {
      "api_url": "https://opencode.ai/zen/go/v1/messages",
      "available_models": [
        {
          "display_name": "MiniMax M3",
