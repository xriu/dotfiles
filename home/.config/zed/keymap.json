// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-r": ["projects::OpenRecent", { "create_new_window": false }],
      "cmd-shift-1": "multi_workspace::NextProject",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd cmd": "project_panel::CollapseAllEntries",
      "cmd-w": "workspace::CloseActiveDock",
      "shift shift": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-7": "editor::ToggleComments",
      "cmd-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "shift shift": "workspace::ToggleZoom",
    },
    "unbind": {
      "cmd-w": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "shift shift": "workspace::ToggleZoom",
    },
    "unbind": {
      "cmd-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift shift": "workspace::ToggleZoom",
      "cmd-t": "workspace::NewTerminal",
    },
  },
  {
    "context": "Agent",
    "bindings": {
      "shift shift": "workspace::ToggleZoom",
    },
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "cmd-w": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "RulesLibrary",
    "unbind": {
      "cmd-w": "workspace::CloseActiveDock",
    },
  },
]
