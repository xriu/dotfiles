{
	"diffMode": "github",
	"logoAnimation": "off",
	"completionSound": "off",
	"awaitingInputSound": "off",
	"todoDisplayMode": "pinned",
	"hasSeenMissionOnboarding": true,
	"showThinkingInMainView": true,
	"enabledPlugins": {
		"core@factory-plugins": true
	},
	"sessionDefaultSettings": {
		"model": "custom:GLM-5",
		"reasoningEffort": "high",
		"autonomyMode": "spec"
	},
	"missionModelSettings": {
		"workerModel": "custom:GLM-5",
		"workerReasoningEffort": "none",
		"validationWorkerModel": "custom:Kimi-K2.5-7",
		"validationWorkerReasoningEffort": "none"
	},
	"commandAllowlist": ["ls", "pwd", "dir"],
	"commandDenylist": [
		"rm -rf /",
		"rm -rf /*",
		"rm -rf .",
		"rm -rf ~",
		"rm -rf ~/*",
		"rm -rf $HOME",
		"rm -r /",
		"rm -r /*",
		"rm -r ~",
		"rm -r ~/*",
		"mkfs",
		"mkfs.ext4",
		"mkfs.ext3",
		"mkfs.vfat",
		"mkfs.ntfs",
		"dd if=/dev/zero of=/dev",
		"dd of=/dev",
		"shutdown",
		"reboot",
		"halt",
		"poweroff",
		"init 0",
		"init 6",
		":(){ :|: & };:",
		":() { :|:& };:",
		"chmod -R 777 /",
		"chmod -R 000 /",
		"chown -R",
		"powershell Remove-Item -Recurse -Force",
		"Format-Volume",
		"format.com"
	],
