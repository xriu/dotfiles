{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"cleanupPeriodDays": 365,
	"env": {
		"CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
		"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
		"CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
		"CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
		"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
		"CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "0",
		"CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_NO_FLICKER": "1",
		"CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-6",
		"DISABLE_TELEMETRY": "1"
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"allow": [
			"Read",
			"Glob",
			"Grep",
			"Edit(~/.claude/*)",
			"Write(~/.claude/*)",
			"ExitPlanMode(*)",
			"WebFetch(domain:*)",
			"WebSearch",
			"Bash(basename *)",
			"Bash(brew info *)",
			"Bash(brew list *)",
			"Bash(cut *)",
			"Bash(date *)",
			"Bash(df *)",
			"Bash(diff *)",
			"Bash(dirname *)",
			"Bash(docker compose logs *)",
			"Bash(docker compose ps *)",
			"Bash(docker images *)",
			"Bash(docker inspect *)",
			"Bash(docker logs *)",
			"Bash(docker ps *)",
			"Bash(du *)",
			"Bash(echo *)",
			"Bash(file *)",
			"Bash(find *)",
			"Bash(gh api *)",
			"Bash(gh issue list *)",
			"Bash(gh issue status *)",
			"Bash(gh issue view *)",
			"Bash(gh pr checks *)",
			"Bash(gh pr diff *)",
			"Bash(gh pr list *)",
			"Bash(gh pr status *)",
			"Bash(gh pr view *)",
			"Bash(gh repo list *)",
			"Bash(gh repo view *)",
			"Bash(gh run list *)",
			"Bash(gh run view *)",
			"Bash(head *)",
			"Bash(hostname *)",
			"Bash(id *)",
			"Bash(jq *)",
			"Bash(ls *)",
			"Bash(md5 *)",
			"Bash(mkdir *)",
			"Bash(npm info *)",
			"Bash(npm list *)",
			"Bash(npm outdated *)",
			"Bash(npm view *)",
			"Bash(pip list *)",
			"Bash(pip show *)",
			"Bash(ps *)",
			"Bash(pwd *)",
			"Bash(python --version *)",
			"Bash(readlink *)",
			"Bash(realpath *)",
			"Bash(rtk curl -s https://checkpoint-api.hashicorp.com/*)",
			"Bash(rtk curl -s https://registry.terraform.io/*)",
			"Bash(rtk git *branch --show-current)",
			"Bash(rtk git *diff *)",
			"Bash(rtk git *log *)",
			"Bash(rtk git *show *)",
			"Bash(rtk git *status*)",
			"Bash(rtk grep *)",
			"Bash(rtk ls *)",
			"Bash(rtk read *)",
			"Bash(*terraform fmt *)",
			"Bash(*terraform init *)",
			"Bash(*terraform output *)",
			"Bash(*terraform plan *)",
			"Bash(*terraform providers *)",
			"Bash(*terraform show *)",
			"Bash(*terraform state list *)",
			"Bash(*terraform state show *)",
			"Bash(*terraform validate *)",
			"Bash(*terraform version *)",
			"Bash(*terraform workspace *)",
			"Bash(ruby --version *)",
			"Bash(shasum *)",
			"Bash(sort *)",
			"Bash(stat *)",
			"Bash(tail *)",
			"Bash(tr *)",
			"Bash(tree *)",
			"Bash(uname *)",
			"Bash(uniq *)",
			"Bash(wc *)",
			"Bash(which *)",
			"Bash(whoami *)",
			"Bash(yq *)",
			"mcp__plugin_*",
			"mcp__claude_ai_*",
			"mcp__atlassian__getTeamworkGraphContext",
			"mcp__atlassian__getTeamworkGraphObject"
		],
		"deny": [
			"Bash(dd *)",
			"Bash(diskutil *)",
			"Bash(mkfs *)",
			"Bash(rm -rf . *)",
			"Bash(rm -rf .)",
			"Bash(rm -rf / *)",
			"Bash(rm -rf /)",
			"Bash(rm -rf /* *)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~ *)",
			"Bash(rm -rf ~)",
			"Bash(rm -rf $HOME *)",
			"Bash(rm -rf $HOME)",
			"Bash(sudo rm -rf *)",
			"Bash(*terraform apply *)",
			"Bash(*terraform destroy *)",
			"Read(./.env.*)",
			"Read(./.env)",
			"Read(./config/credentials.json)",
			"Read(./secrets/**)",
			"Read(~/.aws/**)",
			"Read(~/.ssh/**)"
		],
		"ask": [
			"Bash(chmod 777 *)",
			"Bash(curl *)",
			"Bash(docker compose down *)",
			"Bash(docker compose up *)",
			"Bash(docker exec *)",
			"Bash(docker rm *)",
			"Bash(docker run *)",
			"Bash(docker system *)",
			"Bash(gh api -X *)",
			"Bash(gh issue close *)",
			"Bash(gh issue create *)",
			"Bash(gh pr close *)",
			"Bash(gh pr create *)",
			"Bash(gh pr merge *)",
			"Bash(gh repo delete *)",
			"Bash(git branch -d *)",
			"Bash(git branch -D *)",
			"Bash(git checkout -B *)",
			"Bash(git clean *)",
			"Bash(git merge *)",
			"Bash(git push *)",
			"Bash(git rebase *)",
			"Bash(git reset --hard *)",
			"Bash(git rm *)",
			"Bash(git stash clear *)",
			"Bash(git stash drop *)",
			"Bash(node *)",
			"Bash(npm exec *)",
			"Bash(npm install *)",
			"Bash(npm publish *)",
			"Bash(npm run *)",
			"Bash(npx *)",
			"Bash(rm *)",
			"Bash(*terraform import *)",
			"Bash(*terraform state mv *)",
			"Bash(*terraform state push *)",
			"Bash(*terraform state rm *)",
			"Bash(*terraform taint *)",
			"Bash(*terraform untaint *)",
			"Bash(sudo *)",
			"Bash(wget *)"
		],
		"defaultMode": "acceptEdits",
		"additionalDirectories": ["~/.claude/"]
	},
	"model": "claude-opus-4-6[1m]",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "rtk hook claude"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bash /Users/xavier.riu/dotfiles/home/.claude/statusline.sh"
	},
	"enabledPlugins": {
		"agent-sdk-dev@claude-code-plugins": true,
		"plugin-dev@claude-code-plugins": true,
		"ralph-wiggum@claude-code-plugins": true,
		"slop-review@slop-review": true,
		"typescript-lsp@claude-plugins-official": true
	},
	"extraKnownMarketplaces": {
		"slop-review": {
			"source": {
				"source": "github",
				"repo": "dbachelder/slop-review"
			}
		},
		"claude-code-plugins": {
			"source": {
				"source": "github",
				"repo": "anthropics/claude-code"
			}
		}
	},
	"theme": "dark"
}
