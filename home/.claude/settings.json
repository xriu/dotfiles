{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"cleanupPeriodDays": 365,
	"env": {
		"CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
		"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
		"CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
		"CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
		"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
		"CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_NO_FLICKER": "1",
		"CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-6",
		"DISABLE_TELEMETRY": "1"
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"allow": [
			"Read",
			"Glob",
			"Grep",
			"Task",
			"Bash(basename *)",
			"Bash(diff *)",
			"Bash(dirname *)",
			"Bash(file *)",
			"Bash(ls *)",
			"Bash(md5 *)",
			"Bash(readlink *)",
			"Bash(realpath *)",
			"Bash(shasum *)",
			"Bash(stat *)",
			"Bash(tree *)",
			"Bash(gh pr view *)",
			"Bash(gh pr list *)",
			"Bash(gh pr diff *)",
			"Bash(gh pr checks *)",
			"Bash(gh pr status *)",
			"Bash(gh issue view *)",
			"Bash(gh issue list *)",
			"Bash(gh issue status *)",
			"Bash(gh repo view *)",
			"Bash(gh repo list *)",
			"Bash(gh run view *)",
			"Bash(gh run list *)",
			"Bash(gh api *)",
			"Bash(docker ps *)",
			"Bash(docker logs *)",
			"Bash(docker images *)",
			"Bash(docker inspect *)",
			"Bash(docker compose ps *)",
			"Bash(docker compose logs *)",
			"Bash(date *)",
			"Bash(df *)",
			"Bash(du *)",
			"Bash(hostname *)",
			"Bash(id *)",
			"Bash(ps *)",
			"Bash(pwd *)",
			"Bash(uname *)",
			"Bash(whoami *)",
			"Bash(cut *)",
			"Bash(jq *)",
			"Bash(sort *)",
			"Bash(tr *)",
			"Bash(uniq *)",
			"Bash(wc *)",
			"Bash(yq *)",
			"Bash(brew info *)",
			"Bash(brew list *)",
			"Bash(npm list *)",
			"Bash(npm info *)",
			"Bash(npm outdated *)",
			"Bash(npm view *)",
			"Bash(pip list *)",
			"Bash(pip show *)",
			"Bash(python --version *)",
			"Bash(ruby --version *)",
			"Bash(find *)",
			"Bash(mkdir *)",
			"Bash(which *)",
			"ExitPlanMode(*)",
			"Fetch(*)",
			"WebFetch(domain:*)",
			"WebSearch",
			"mcp__plugin_*",
			"mcp__claude_ai_*"
		],
		"deny": [
			"Read(./.env)",
			"Read(./.env.*)",
			"Read(./secrets/**)",
			"Read(./config/credentials.json)",
			"Read(~/.aws/**)",
			"Read(~/.ssh/**)",
			"Bash(dd *)",
			"Bash(diskutil *)",
			"Bash(mkfs *)",
			"Bash(rm -rf .)",
			"Bash(rm -rf ./)",
			"Bash(rm -rf /)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~)",
			"Bash(rm -rf $HOME)",
			"Bash(rm -rf . *)",
			"Bash(rm -rf ./ *)",
			"Bash(rm -rf / *)",
			"Bash(rm -rf /* *)",
			"Bash(rm -rf ~ *)",
			"Bash(rm -rf $HOME *)",
			"Bash(sudo rm -rf /)",
			"Bash(sudo rm -rf /*)",
			"Bash(sudo rm -rf / *)",
			"Bash(sudo rm -rf /* *)"
		],
		"ask": [
			"Bash(rm *)",
			"Bash(sudo *)",
			"Bash(git push *)",
			"Bash(git rm *)",
			"Bash(git reset --hard *)",
			"Bash(git clean *)",
			"Bash(git rebase *)",
			"Bash(git merge *)",
			"Bash(git checkout -B *)",
			"Bash(git branch -D *)",
			"Bash(git branch -d *)",
			"Bash(git stash drop *)",
			"Bash(git stash clear *)",
			"Bash(chmod 777 *)",
			"Bash(docker run *)",
			"Bash(docker exec *)",
			"Bash(docker rm *)",
			"Bash(docker system *)",
			"Bash(docker compose up *)",
			"Bash(docker compose down *)",
			"Bash(gh pr merge *)",
			"Bash(gh pr close *)",
			"Bash(gh pr create *)",
			"Bash(gh issue close *)",
			"Bash(gh issue create *)",
			"Bash(gh repo delete *)",
			"Bash(gh api -X *)",
			"Bash(curl *)",
			"Bash(wget *)",
			"Bash(npm install *)",
			"Bash(npm run *)",
			"Bash(npm publish *)",
			"Bash(npm exec *)",
			"Bash(npx *)",
			"Bash(node *)",
			"Bash(echo *)"
		],
		"defaultMode": "acceptEdits"
	},
	"model": "claude-opus-4-6",
	"statusLine": {
		"type": "command",
		"command": "bash /Users/xavier.riu/dotfiles/home/.claude/statusline.sh"
	},
	"enabledPlugins": {
		"slop-review@slop-review": true,
		"ralph-wiggum@claude-code-plugins": true
	},
	"extraKnownMarketplaces": {
		"slop-review": {
			"source": {
				"source": "github",
				"repo": "dbachelder/slop-review"
			}
		},
		"claude-code-plugins": {
			"source": {
				"source": "github",
				"repo": "anthropics/claude-code"
			}
		}
	}
}
