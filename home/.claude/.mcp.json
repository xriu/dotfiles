{
    "mcpServers": {
        "aws-knowledge": {
            "type": "http",
            "url": "https://knowledge-mcp.global.api.aws"
        },
        "aws-mcp": {
            "command": "uvx",
            "args": [
                "mcp-proxy-for-aws==1.6.1",
                "https://aws-mcp.us-east-1.api.aws/mcp",
                "--metadata",
                "AWS_REGION=us-east-1"
            ]
        },
        "costory": {
            "command": "npx",
            "args": ["-y", "mcp-remote", "https://app-api.costory.io/mcp"]
        }
    }
}
