{
  "lastChangelogVersion": "0.68.1",
  "compaction": {
    "reserveTokens": 20000
  },
  "packages": [
    "https://github.com/davebcn87/pi-autoresearch",
    "https://github.com/badlogic/pi-diff-review",
    "npm:@plannotator/pi-extension",
    "npm:pi-interview",
    "npm:pi-review-loop",
    "npm:pi-rewind-hook"
  ],
  "extensions": [
    "~/dotfiles/home/.pi/agent/extensions"
  ],
  "defaultProvider": "synthetic",
  "defaultModel": "hf:zai-org/GLM-5.1",
  "defaultThinkingLevel": "high",
  "customProfileFooter": true,
  "treeFilterMode": "default",
  "theme": "dark",
  "reviewerLoop": {
    "maxIterations": 7,
    "autoTrigger": true,
    "freshContext": true,
    "reviewPrompt": "template:double-check",
    "triggerPatterns": {
      "mode": "extend",
      "patterns": [
        "execute the plan"
      ]
    },
    "exitPatterns": {
      "mode": "extend",
      "patterns": [
        "ship it",
        "ready to merge"
      ]
    },
    "issuesFixedPatterns": {
      "mode": "extend",
      "patterns": [
        "addressed the following"
      ]
    }
  }
}