{
	"lastChangelogVersion": "0.79.0",
	"packages": [
		"npm:@plannotator/pi-extension",
		"npm:pi-bash-live-view",
		"npm:pi-design-deck",
		"npm:pi-interview",
		"npm:pi-lens",
		"npm:pi-markdown-preview",
		"npm:pi-mcp-adapter",
		"npm:pi-powerline-footer",
		"npm:pi-review-loop",
		"npm:pi-rewind",
		"npm:pi-slop-review",
		"npm:pi-smart-fetch"
	],
	"extensions": ["~/dotfiles/home/.pi/agent/extensions"],
	"defaultProvider": "synthetic",
	"defaultModel": "hf:moonshotai/Kimi-K2.6",
	"defaultThinkingLevel": "high",
	"treeFilterMode": "no-tools",
	"theme": "dark",
	"reviewerLoop": {
		"maxIterations": 3,
		"autoTrigger": true,
		"freshContext": true,
		"reviewPrompt": "template:double-check"
	}
}
