{
    "enabled": true,
    "features": {
        "policies": true,
        "permissionGate": true,
        "pathAccess": false
    },
    "pathAccess": {
        "mode": "ask",
        "allowedPaths": []
    },
    "policies": {
        "rules": [
            {
                "id": "secret-files",
                "description": "Files containing secrets",
                "patterns": [
                    {
                        "pattern": "*.env"
                    },
                    {
                        "pattern": "local.env"
                    },
                    {
                        "pattern": ".env.*"
                    },
                    {
                        "pattern": ".env.local"
                    },
                    {
                        "pattern": ".env.production"
                    },
                    {
                        "pattern": ".env.prod"
                    },
                    {
                        "pattern": ".dev.vars"
                    },
                    {
                        "pattern": ".git-credentials"
                    },
                    {
                        "pattern": ".npmrc"
                    }
                ],
                "allowedPatterns": [
                    {
                        "pattern": ".env.example"
                    },
                    {
                        "pattern": ".env.sample"
                    },
                    {
                        "pattern": ".env.test"
                    },
                    {
                        "pattern": "*.example.env"
                    },
                    {
                        "pattern": "*.sample.env"
                    },
                    {
                        "pattern": "*.test.env"
                    }
                ],
                "protection": "noAccess",
                "onlyIfExists": true
            },
            {
                "id": "secret-paths",
                "description": "Project directories and user config paths that may contain secrets",
                "patterns": [
                    {
                        "pattern": "secrets"
                    },
                    {
                        "pattern": "secrets/**"
                    },
                    {
                        "pattern": "private"
                    },
                    {
                        "pattern": "private/**"
                    },
                    {
                        "pattern": "credentials"
                    },
                    {
                        "pattern": "credentials/**"
                    },
                    {
                        "pattern": "certs"
                    },
                    {
                        "pattern": "certs/**"
                    },
                    {
                        "pattern": "~/.ssh"
                    },
                    {
                        "pattern": "~/.ssh/**"
                    },
                    {
                        "pattern": "~/.aws"
                    },
                    {
                        "pattern": "~/.aws/**"
                    },
                    {
                        "pattern": "~/.gnupg"
                    },
                    {
                        "pattern": "~/.gnupg/**"
                    },
                    {
                        "pattern": "~/.config/gcloud"
                    },
                    {
                        "pattern": "~/.config/gcloud/**"
                    },
                    {
                        "pattern": "~/.docker/config.json"
                    },
                    {
                        "pattern": "~/.npmrc"
                    }
                ],
                "protection": "noAccess",
                "onlyIfExists": true
            },
            {
                "id": "private-key-and-cert-files",
                "description": "Private key and certificate files",
                "patterns": [
                    {
                        "pattern": "*.pem"
                    },
                    {
                        "pattern": "*.key"
                    },
                    {
                        "pattern": "*.p12"
                    },
                    {
                        "pattern": "*.pfx"
                    },
                    {
                        "pattern": "*.crt"
                    }
                ],
                "protection": "noAccess",
                "onlyIfExists": true
            },
            {
                "id": "write-protected-paths",
                "description": "Directories that should not be modified by the agent",
                "patterns": [
                    {
                        "pattern": ".git"
                    },
                    {
                        "pattern": ".git/**"
                    },
                    {
                        "pattern": "node_modules"
                    },
                    {
                        "pattern": "node_modules/**"
                    }
                ],
                "protection": "readOnly",
                "onlyIfExists": true
            }
        ]
    },
    "permissionGate": {
        "patterns": [
            {
                "pattern": "sudo",
                "description": "Commands run with superuser privileges"
            },
            {
                "pattern": "git push",
                "description": "Push commits to remote"
            },
            {
                "pattern": "git push --force",
                "description": "Force push, can overwrite remote history"
            },
            {
                "pattern": "git push -f",
                "description": "Force push (short flag)"
            },
            {
                "pattern": "git rm",
                "description": "Remove files from working tree and index"
            },
            {
                "pattern": "git reset --hard",
                "description": "Hard reset, discards all uncommitted changes"
            },
            {
                "pattern": "git clean",
                "description": "Remove untracked files from working tree"
            },
            {
                "pattern": "git rebase",
                "description": "Rewrite commit history"
            },
            {
                "pattern": "git merge",
                "description": "Merge branches"
            },
            {
                "pattern": "git checkout -B",
                "description": "Force create/reset branch"
            },
            {
                "pattern": "git branch -D",
                "description": "Force delete a branch"
            },
            {
                "pattern": "git branch -d",
                "description": "Delete a branch"
            },
            {
                "pattern": "git stash drop",
                "description": "Drop a stash entry"
            },
            {
                "pattern": "git stash clear",
                "description": "Remove all stash entries"
            },
            {
                "pattern": "dd",
                "description": "Disk copying command that can overwrite data"
            },
            {
                "pattern": "mkfs",
                "description": "Command to create a filesystem, which can erase data on a disk"
            },
            {
                "pattern": "chmod 777",
                "description": "Setting read/write/execute permissions for all users"
            }
        ],
        "customPatterns": [],
        "requireConfirmation": true,
        "allowedPatterns": [
            {
                "pattern": ".git/index.lock",
                "description": "Safe: removes a single Git lock file"
            }
        ],
        "autoDenyPatterns": []
    }
}
