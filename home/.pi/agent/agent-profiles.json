        "provider": "github-copilot",
        "model": "gpt-5.4-mini",
        "thinkingLevel": "minimal"
      },
      "agents": {
        "context-builder": "github-copilot/gpt-5-mini",
        "delegate": "github-copilot/gpt-5.4-mini",
        "researcher": "github-copilot/gpt-5-mini",
        "scout": "github-copilot/gpt-5.4-mini",
        "planner": "github-copilot/gpt-5-mini",
        "reviewer": "github-copilot/gpt-5-mini",
