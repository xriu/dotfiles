{
	"mcpServers": {
		"aws": {
			"command": "uvx",
			"args": [
				"mcp-proxy-for-aws@latest",
				"https://aws-mcp.us-east-1.api.aws/mcp",
				"--region",
				"us-east-1",
				"--metadata",
				"AWS_REGION=us-east-1"
			]
		},
		"aws-knowledge": {
			"type": "http",
			"url": "https://knowledge-mcp.global.api.aws"
		},
		"costory": {
			"command": "npx",
			"args": ["-y", "mcp-remote", "https://app-api.costory.io/mcp"]
		}
	}
}
