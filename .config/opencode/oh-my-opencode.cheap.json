{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/refs/heads/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "disabled_mcps": [],
  "agents": {
    "prometheus": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "metis": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "atlas": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "sisyphus": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "sisyphus-junior": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex"
    },
    "momus": {
      "model": "openai/gpt-5.2"
    },
    "oracle": {
      "model": "openai/gpt-5.2"
    },
    "librarian": {
      "model": "synthetic/hf:MiniMaxAI/MiniMax-M2.1"
    },
    "explore": {
      "model": "synthetic/hf:MiniMaxAI/MiniMax-M2.1"
    },
    "multimodal-looker": {
      "model": "google/gemini-3-flash-preview"
    },
    "build": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    },
    "plan": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "synthetic/hf:moonshotai/Kimi-K2.5",
      "variant": "max"
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "synthetic/hf:MiniMaxAI/MiniMax-M2.1",
      "variant": "max"
    },
    "unspecified-low": {
      "model": "synthetic/hf:MiniMaxAI/MiniMax-M2.1"
    },
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview"
    },
    "quick": {
      "model": "opencode/minimax-m2.5-free"
    },
    "writing": {
      "model": "opencode/minimax-m2.5-free"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  }
}
